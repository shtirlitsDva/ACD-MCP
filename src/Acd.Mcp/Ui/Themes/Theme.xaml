<!--
  Centralised dark theme for the Acd.Mcp REPL palette.

  Matches AutoCAD 2025's own dark chrome. Every control type that has OS-themed
  parts (Button, TextBox, ListBox, ListBoxItem, ScrollBar + Thumb + RepeatButton,
  Expander + its toggle, Border) has a FULL ControlTemplate — never just a brush
  override on top of the default OS template, because that produces a "light
  popup with light text" bug for dropdowns, light scrollbar tracks, default-blue
  selection chrome, etc.

  Views must never use inline colours, fonts, or styles. They reference resources
  here via {StaticResource} (literal lookup at parse time) or {DynamicResource}
  (live lookup, used for any brush that might change for a future light-mode
  swap).
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!--  COLOURS                                                              -->
    <!--  Blue-slate palette adopted from DimensioneringV2 — warmer than pure  -->
    <!--  grey and reads much better against AutoCAD's own chrome.             -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <Color x:Key="Color.Bg.Window">#FF2D3442</Color>          <!-- palette body, deepest -->
    <Color x:Key="Color.Bg.Surface">#FF3B4453</Color>         <!-- toolbar/section strips -->
    <Color x:Key="Color.Bg.Control">#FF4A5568</Color>         <!-- button bg -->
    <Color x:Key="Color.Bg.ControlHover">#FF5A6A80</Color>
    <Color x:Key="Color.Bg.ControlPressed">#FF6A7A90</Color>
    <Color x:Key="Color.Bg.RowHover">#FF3B4453</Color>        <!-- list row hover -->
    <Color x:Key="Color.Bg.Selected">#FF4A6B8A</Color>        <!-- blue selection -->
    <Color x:Key="Color.Bg.SelectedHover">#FF6A9BBA</Color>

    <Color x:Key="Color.Bg.Inset">#FF252D3A</Color>           <!-- inset / read-only display bg -->

    <Color x:Key="Color.Border.Subtle">#FF5A6A80</Color>
    <Color x:Key="Color.Border.Focused">#FF6A9BBA</Color>

    <Color x:Key="Color.Fg.Primary">#FFFFFFFF</Color>
    <Color x:Key="Color.Fg.Secondary">#FFA0AEC0</Color>
    <Color x:Key="Color.Fg.Disabled">#FF6A7280</Color>
    <Color x:Key="Color.Fg.Failure">#FFFCA5A5</Color>
    <Color x:Key="Color.Fg.Caret">#FFFFFFFF</Color>

    <Color x:Key="Color.ScrollBar.Track">#FF2D3442</Color>
    <Color x:Key="Color.ScrollBar.Thumb">#FF4A5568</Color>
    <Color x:Key="Color.ScrollBar.ThumbHover">#FF5A6A80</Color>
    <Color x:Key="Color.ScrollBar.ThumbDragging">#FF6A7A90</Color>

    <Color x:Key="Color.Accent">#FF6A9BBA</Color>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!--  BRUSHES                                                              -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <SolidColorBrush x:Key="Brush.Bg.Window"          Color="{StaticResource Color.Bg.Window}"/>
    <SolidColorBrush x:Key="Brush.Bg.Surface"         Color="{StaticResource Color.Bg.Surface}"/>
    <SolidColorBrush x:Key="Brush.Bg.Control"         Color="{StaticResource Color.Bg.Control}"/>
    <SolidColorBrush x:Key="Brush.Bg.ControlHover"    Color="{StaticResource Color.Bg.ControlHover}"/>
    <SolidColorBrush x:Key="Brush.Bg.ControlPressed"  Color="{StaticResource Color.Bg.ControlPressed}"/>
    <SolidColorBrush x:Key="Brush.Bg.RowHover"        Color="{StaticResource Color.Bg.RowHover}"/>
    <SolidColorBrush x:Key="Brush.Bg.Selected"        Color="{StaticResource Color.Bg.Selected}"/>
    <SolidColorBrush x:Key="Brush.Bg.SelectedHover"   Color="{StaticResource Color.Bg.SelectedHover}"/>

    <SolidColorBrush x:Key="Brush.Border.Subtle"      Color="{StaticResource Color.Border.Subtle}"/>
    <SolidColorBrush x:Key="Brush.Border.Focused"     Color="{StaticResource Color.Border.Focused}"/>

    <SolidColorBrush x:Key="Brush.Fg.Primary"         Color="{StaticResource Color.Fg.Primary}"/>
    <SolidColorBrush x:Key="Brush.Fg.Secondary"       Color="{StaticResource Color.Fg.Secondary}"/>
    <SolidColorBrush x:Key="Brush.Fg.Disabled"        Color="{StaticResource Color.Fg.Disabled}"/>
    <SolidColorBrush x:Key="Brush.Fg.Failure"         Color="{StaticResource Color.Fg.Failure}"/>
    <SolidColorBrush x:Key="Brush.Fg.Caret"           Color="{StaticResource Color.Fg.Caret}"/>

    <SolidColorBrush x:Key="Brush.Bg.Inset"           Color="{StaticResource Color.Bg.Inset}"/>

    <SolidColorBrush x:Key="Brush.ScrollBar.Track"        Color="{StaticResource Color.ScrollBar.Track}"/>
    <SolidColorBrush x:Key="Brush.ScrollBar.Thumb"        Color="{StaticResource Color.ScrollBar.Thumb}"/>
    <SolidColorBrush x:Key="Brush.ScrollBar.ThumbHover"   Color="{StaticResource Color.ScrollBar.ThumbHover}"/>
    <SolidColorBrush x:Key="Brush.ScrollBar.ThumbDragging" Color="{StaticResource Color.ScrollBar.ThumbDragging}"/>

    <SolidColorBrush x:Key="Brush.Accent"             Color="{StaticResource Color.Accent}"/>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!--  FONTS                                                                -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <FontFamily x:Key="Font.Ui">Segoe UI</FontFamily>
    <FontFamily x:Key="Font.Mono">Consolas</FontFamily>
    <sys:Double x:Key="Font.Size.Body">12</sys:Double>
    <sys:Double x:Key="Font.Size.Mono">12</sys:Double>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!--  BASE TEXT                                                            -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Primary}"/>
        <Setter Property="FontFamily" Value="{StaticResource Font.Ui}"/>
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}"/>
    </Style>

    <Style x:Key="Text.Mono" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontFamily" Value="{StaticResource Font.Mono}"/>
    </Style>

    <Style x:Key="Text.Secondary" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Secondary}"/>
    </Style>

    <Style x:Key="Text.SectionHeader" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Secondary}"/>
    </Style>

    <!-- Log row header: monospace + colour driven by IsSuccess on the bound VM. -->
    <Style x:Key="Text.LogRowHeader" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontFamily" Value="{StaticResource Font.Mono}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Primary}"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Failure}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!--  BUTTON  — full template, hover / pressed / disabled / focused        -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <Style TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource Brush.Bg.Control}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="FontFamily" Value="{StaticResource Font.Ui}"/>
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="2"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"
                                          SnapsToDevicePixels="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Bg.ControlHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Bg.ControlPressed}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.Border.Focused}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Disabled}"/>
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Bg.Control}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!--  TEXTBOX  — full template, IsReadOnly trigger drops the chrome for    -->
    <!--             the detail-display textboxes inside the log expander.     -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource Brush.Bg.Control}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Primary}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource Brush.Fg.Caret}"/>
        <Setter Property="SelectionBrush" Value="{DynamicResource Brush.Bg.Selected}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="FontFamily" Value="{StaticResource Font.Ui}"/>
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="2"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Padding="{TemplateBinding Padding}"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.Border.Focused}"/>
                        </Trigger>
                        <Trigger Property="IsReadOnly" Value="True">
                            <Setter TargetName="Bd" Property="BorderThickness" Value="0"/>
                            <Setter TargetName="Bd" Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="0"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Disabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!--  SCROLLBAR  — full template, modern minimal (thumb only, no arrows).  -->
    <!--  Vertical and horizontal templates share Thumb / RepeatButton styles. -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <Style x:Key="ScrollBar.Thumb" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="ThumbBg"
                            Background="{DynamicResource Brush.ScrollBar.Thumb}"
                            CornerRadius="3"
                            Margin="2"
                            SnapsToDevicePixels="True"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBg" Property="Background" Value="{DynamicResource Brush.ScrollBar.ThumbHover}"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBg" Property="Background" Value="{DynamicResource Brush.ScrollBar.ThumbDragging}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ScrollBar.PageButton" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <!-- Transparent invisible track surface — page-up / page-down clicks. -->
                    <Border Background="Transparent"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="ScrollBar.Vertical" TargetType="ScrollBar">
        <Grid Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
            <Track x:Name="PART_Track" IsDirectionReversed="True">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                  Style="{StaticResource ScrollBar.PageButton}"/>
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource ScrollBar.Thumb}"/>
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                  Style="{StaticResource ScrollBar.PageButton}"/>
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>

    <ControlTemplate x:Key="ScrollBar.Horizontal" TargetType="ScrollBar">
        <Grid Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
            <Track x:Name="PART_Track">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageLeftCommand"
                                  Style="{StaticResource ScrollBar.PageButton}"/>
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource ScrollBar.Thumb}"/>
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageRightCommand"
                                  Style="{StaticResource ScrollBar.PageButton}"/>
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="{DynamicResource Brush.ScrollBar.Track}"/>
        <Setter Property="Width" Value="10"/>
        <Setter Property="MinWidth" Value="10"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template" Value="{StaticResource ScrollBar.Vertical}"/>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="MinWidth" Value="0"/>
                <Setter Property="Height" Value="10"/>
                <Setter Property="MinHeight" Value="10"/>
                <Setter Property="Template" Value="{StaticResource ScrollBar.Horizontal}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ScrollViewer: just give it our dark background. The PART_VerticalScrollBar
         and PART_HorizontalScrollBar inside default ScrollViewer template will
         resolve our implicit ScrollBar style above and inherit dark chrome. -->
    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Primary}"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!--  LISTBOX + LISTBOXITEM  — full templates                              -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{DynamicResource Brush.Bg.Surface}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer Focusable="False"
                                      HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                      VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}">
                            <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Primary}"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Bg.RowHover}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Bg.Selected}"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Bg.SelectedHover}"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!--  EXPANDER + its header toggle  — full templates                       -->
    <!--  ExpandDirection=Down assumed; that's the only one we use. The chev-  -->
    <!--  ron is a Path with a RenderTransform that rotates on IsChecked.      -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <Style x:Key="Expander.HeaderToggle" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Primary}"/>
        <Setter Property="Padding" Value="4,3"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="HeaderBd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <DockPanel LastChildFill="True">
                            <Grid DockPanel.Dock="Left"
                                  Width="12" Height="12"
                                  VerticalAlignment="Center"
                                  Margin="2,0,6,0">
                                <Path x:Name="Chevron"
                                      Width="6" Height="9"
                                      Stretch="Fill"
                                      Fill="{DynamicResource Brush.Fg.Secondary}"
                                      Data="M 0,0 L 6,4.5 L 0,9 Z"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform>
                                        <RotateTransform Angle="0"/>
                                    </Path.RenderTransform>
                                </Path>
                            </Grid>
                            <ContentPresenter VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </DockPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HeaderBd" Property="Background" Value="{DynamicResource Brush.Bg.RowHover}"/>
                            <Setter TargetName="Chevron"  Property="Fill"       Value="{DynamicResource Brush.Fg.Primary}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <!-- Swap the whole RenderTransform: named children inside a
                                 Freezable's property-element block aren't reachable by
                                 TargetName, so we replace the transform value wholesale. -->
                            <Setter TargetName="Chevron" Property="RenderTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="90"/>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="Chevron" Property="Fill" Value="{DynamicResource Brush.Fg.Primary}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Expander">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Primary}"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Expander">
                    <Border Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                        <DockPanel LastChildFill="True">
                            <ToggleButton DockPanel.Dock="Top"
                                          IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Style="{StaticResource Expander.HeaderToggle}"
                                          Content="{TemplateBinding Header}"
                                          ContentTemplate="{TemplateBinding HeaderTemplate}"
                                          HorizontalContentAlignment="Stretch"/>
                            <ContentPresenter x:Name="ExpandSite"
                                              Visibility="Collapsed"
                                              Focusable="False"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </DockPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!--  HELPER STYLES                                                         -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <!-- Divider line for between sections. -->
    <Style x:Key="Border.Divider" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush.Border.Subtle}"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

    <!-- Section panel: a Border with the surface background, used to group
         related controls (the toolbar strip, the log-header strip). -->
    <Style x:Key="Border.SectionStrip" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush.Bg.Surface}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="6,4"/>
    </Style>

    <!-- Detail row container inside an expanded log entry. Uses the inset
         (deepest) background so it visually nests inside the surface strips. -->
    <Style x:Key="Border.DetailBox" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush.Bg.Inset}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="CornerRadius" Value="3"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!--  CHECKBOX  — full template, dark theme.                                -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Primary}"/>
        <Setter Property="Background" Value="{DynamicResource Brush.Bg.Inset}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="Box" Width="14" Height="14"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="2"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                SnapsToDevicePixels="True">
                            <Path x:Name="Check"
                                  Width="10" Height="10"
                                  Stretch="Fill"
                                  Stroke="{DynamicResource Brush.Fg.Primary}"
                                  StrokeThickness="2"
                                  Data="M 0,5 L 4,9 L 10,1"
                                  Visibility="Collapsed"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                        <ContentPresenter VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource Brush.Bg.Selected}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Brush.Border.Focused}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!--  SLIDE SWITCH (Test ◀────▶ Live)  — hand-rolled ToggleButton style.    -->
    <!--  ~ 30 lines as the spec called for. Distinct red accent when Live.    -->
    <!--  IsChecked = false → Test (slate). IsChecked = true → Live (red).     -->
    <!-- ════════════════════════════════════════════════════════════════════ -->

    <Color x:Key="Color.SlideSwitch.Live">#FFB85C5C</Color>
    <SolidColorBrush x:Key="Brush.SlideSwitch.Live" Color="{StaticResource Color.SlideSwitch.Live}"/>

    <Style x:Key="SlideSwitch.TestLive" TargetType="ToggleButton">
        <Setter Property="Background" Value="{DynamicResource Brush.Bg.Inset}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Subtle}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Fg.Primary}"/>
        <Setter Property="Width" Value="120"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Track"
                            CornerRadius="13"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <!-- Both labels are always present; the inactive one
                                 fades to Fg.Disabled. Mono font keeps the
                                 width stable as state flips. -->
                            <TextBlock x:Name="TestLabel"
                                       Text="Test"
                                       FontFamily="{StaticResource Font.Mono}"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Margin="14,0,0,0"
                                       Foreground="{DynamicResource Brush.Fg.Primary}"/>
                            <TextBlock x:Name="LiveLabel"
                                       Text="Live"
                                       FontFamily="{StaticResource Font.Mono}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,14,0"
                                       Foreground="{DynamicResource Brush.Fg.Disabled}"/>
                            <Border x:Name="Knob"
                                    Width="50" Height="20"
                                    CornerRadius="10"
                                    Background="{DynamicResource Brush.Bg.Control}"
                                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                    BorderThickness="1"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="2,0,0,0">
                                <TextBlock x:Name="KnobText"
                                           Text="Test"
                                           FontFamily="{StaticResource Font.Mono}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.Fg.Primary}"/>
                            </Border>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <!-- Slide the knob to the right, swap label
                                 fades, paint the track red. No animation
                                 storyboard — keeps it simple; the user
                                 wanted hand-rolled-and-clean. -->
                            <Setter TargetName="Knob"      Property="HorizontalAlignment" Value="Right"/>
                            <Setter TargetName="Knob"      Property="Margin"              Value="0,0,2,0"/>
                            <Setter TargetName="Knob"      Property="Background"          Value="{DynamicResource Brush.SlideSwitch.Live}"/>
                            <Setter TargetName="KnobText"  Property="Text"                Value="Live"/>
                            <Setter TargetName="Track"     Property="BorderBrush"         Value="{DynamicResource Brush.SlideSwitch.Live}"/>
                            <Setter TargetName="TestLabel" Property="Foreground"          Value="{DynamicResource Brush.Fg.Disabled}"/>
                            <Setter TargetName="LiveLabel" Property="Foreground"          Value="{DynamicResource Brush.Fg.Primary}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Track" Property="BorderBrush"
                                    Value="{DynamicResource Brush.Border.Focused}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
