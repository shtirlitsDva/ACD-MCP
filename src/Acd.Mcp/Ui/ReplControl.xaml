<UserControl x:Class="Acd.Mcp.Ui.ReplControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="700">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="80"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*" MinHeight="120"/>
        </Grid.RowDefinitions>

        <!-- Editor: AvalonEdit with C# syntax highlighting.
             Name="Editor" exposes it to the code-behind, which two-way-syncs
             the text into the VM's CurrentCode property. -->
        <Border Grid.Row="0" BorderBrush="#FFCCCCCC" BorderThickness="0,0,0,1">
            <avalon:TextEditor x:Name="Editor"
                               SyntaxHighlighting="C#"
                               FontFamily="Consolas"
                               FontSize="12"
                               ShowLineNumbers="True"
                               WordWrap="False"
                               HorizontalScrollBarVisibility="Auto"
                               VerticalScrollBarVisibility="Auto">
                <avalon:TextEditor.InputBindings>
                    <KeyBinding Key="Enter" Modifiers="Control" Command="{Binding RunCommand}"/>
                </avalon:TextEditor.InputBindings>
            </avalon:TextEditor>
        </Border>

        <!-- Toolbar: Run / Reset / Clear + live status string -->
        <Border Grid.Row="1" BorderBrush="#FFCCCCCC" BorderThickness="0,0,0,1" Padding="6,4">
            <DockPanel LastChildFill="True">
                <Button Content="Run (Ctrl+Enter)"
                        Command="{Binding RunCommand}"
                        Padding="10,4" Margin="0,0,6,0"/>
                <Button Content="Reset session"
                        Command="{Binding ResetSessionCommand}"
                        Padding="10,4" Margin="0,0,6,0"/>
                <Button Content="Clear log"
                        Command="{Binding ClearLogCommand}"
                        Padding="10,4" Margin="0,0,12,0"/>
                <TextBlock Text="{Binding StatusLine}"
                           VerticalAlignment="Center"
                           Opacity="0.7"/>
            </DockPanel>
        </Border>

        <!-- Section header for the log -->
        <Border Grid.Row="2" Background="#FFF0F0F0" Padding="6,3">
            <TextBlock Text="Execution log (newest first — click a row to see details)"
                       FontWeight="SemiBold"
                       Opacity="0.8"/>
        </Border>

        <!-- Log list. Each row is an Expander; header is one fixed-pitch line,
             detail body shows code + result. -->
        <ListBox Grid.Row="3"
                 ItemsSource="{Binding LogEntries}"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 BorderThickness="0">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Expander>
                        <Expander.Header>
                            <TextBlock Text="{Binding Header}"
                                       FontFamily="Consolas"
                                       Foreground="{Binding IsSuccess, Converter={StaticResource SuccessBrushConverter}}"/>
                        </Expander.Header>
                        <Grid Margin="22,4,6,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Code" FontWeight="SemiBold" Margin="0,2,0,2"/>
                            <Border Grid.Row="1"
                                    Background="#FFFAFAFA" BorderBrush="#FFE0E0E0" BorderThickness="1"
                                    Padding="6">
                                <TextBox Text="{Binding Code, Mode=OneWay}"
                                         IsReadOnly="True"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontFamily="Consolas"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"/>
                            </Border>

                            <TextBlock Grid.Row="2" Text="Result" FontWeight="SemiBold" Margin="0,8,0,2"/>
                            <Border Grid.Row="3"
                                    Background="#FFFAFAFA" BorderBrush="#FFE0E0E0" BorderThickness="1"
                                    Padding="6">
                                <TextBox Text="{Binding Detail, Mode=OneWay}"
                                         IsReadOnly="True"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontFamily="Consolas"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"/>
                            </Border>
                        </Grid>
                    </Expander>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>

    <UserControl.Resources>
        <local:SuccessBrushConverter x:Key="SuccessBrushConverter"
                                     xmlns:local="clr-namespace:Acd.Mcp.Ui"/>
    </UserControl.Resources>
</UserControl>
