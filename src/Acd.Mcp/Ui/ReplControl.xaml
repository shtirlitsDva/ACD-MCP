<UserControl x:Class="Acd.Mcp.Ui.ReplControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="700"
             Background="{DynamicResource Brush.Bg.Window}"
             Foreground="{DynamicResource Brush.Fg.Primary}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Acd.Mcp;component/Ui/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="80"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*" MinHeight="120"/>
        </Grid.RowDefinitions>

        <!-- Editor: AvalonEdit with C# syntax highlighting.
             Name="Editor" exposes it to the code-behind, which two-way-syncs
             the text into the VM's CurrentCode property and applies dark
             theming to the syntax-colour table (AvalonEdit bypasses WPF
             styling for token colours, so its theming is done in code). -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource Brush.Border.Subtle}"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource Brush.Bg.Window}">
            <avalon:TextEditor x:Name="Editor"
                               SyntaxHighlighting="C#"
                               ShowLineNumbers="True"
                               WordWrap="False"
                               HorizontalScrollBarVisibility="Auto"
                               VerticalScrollBarVisibility="Auto"
                               Background="{DynamicResource Brush.Bg.Window}"
                               Foreground="{DynamicResource Brush.Fg.Primary}"
                               LineNumbersForeground="{DynamicResource Brush.Fg.Secondary}">
                <avalon:TextEditor.InputBindings>
                    <KeyBinding Key="Enter" Modifiers="Control" Command="{Binding RunCommand}"/>
                </avalon:TextEditor.InputBindings>
            </avalon:TextEditor>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource Border.SectionStrip}">
            <DockPanel LastChildFill="True">
                <Button Content="Run (Ctrl+Enter)"
                        Command="{Binding RunCommand}"
                        Margin="0,0,6,0"/>
                <Button Content="Reset session"
                        Command="{Binding ResetSessionCommand}"
                        Margin="0,0,6,0"/>
                <Button Content="Clear log"
                        Command="{Binding ClearLogCommand}"
                        Margin="0,0,12,0"/>
                <TextBlock Text="{Binding StatusLine}"
                           Style="{StaticResource Text.Secondary}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Section header for the log -->
        <Border Grid.Row="2" Style="{StaticResource Border.SectionStrip}">
            <TextBlock Text="Execution log (newest first — click a row to see details)"
                       Style="{StaticResource Text.SectionHeader}"/>
        </Border>

        <!-- Log list. Each row is an Expander; header is one fixed-pitch line,
             detail body shows code + result. All styling lives in Theme.xaml. -->
        <ListBox Grid.Row="3" ItemsSource="{Binding LogEntries}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Expander>
                        <Expander.Header>
                            <TextBlock Text="{Binding Header}"
                                       Style="{StaticResource Text.LogRowHeader}"/>
                        </Expander.Header>
                        <Grid Margin="22,4,6,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Code"
                                       Style="{StaticResource Text.SectionHeader}"
                                       Margin="0,2,0,2"/>
                            <Border Grid.Row="1" Style="{StaticResource Border.DetailBox}">
                                <TextBox Text="{Binding Code, Mode=OneWay}"
                                         Style="{StaticResource {x:Type TextBox}}"
                                         IsReadOnly="True"
                                         FontFamily="{StaticResource Font.Mono}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"/>
                            </Border>

                            <TextBlock Grid.Row="2"
                                       Text="Result"
                                       Style="{StaticResource Text.SectionHeader}"
                                       Margin="0,8,0,2"/>
                            <Border Grid.Row="3" Style="{StaticResource Border.DetailBox}">
                                <TextBox Text="{Binding Detail, Mode=OneWay}"
                                         Style="{StaticResource {x:Type TextBox}}"
                                         IsReadOnly="True"
                                         FontFamily="{StaticResource Font.Mono}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"/>
                            </Border>
                        </Grid>
                    </Expander>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
