<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Library</OutputType>
    <AssemblyName>Acd.Mcp</AssemblyName>
    <RootNamespace>Acd.Mcp</RootNamespace>
    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>

    <!-- Required for plugin loaders that resolve dependencies from the
         plugin folder (DevReload's AssemblyDependencyResolver path). -->
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>

    <!-- WPF needed for the SCRIPT + BATCH palette. PresentationFramework /
         PresentationCore / WindowsBase / System.Xaml must be added to DevReload's
         shared-assemblies list so XAML resolves to the same types AutoCAD
         already uses. -->
    <UseWPF>true</UseWPF>

    <!-- Required by ScriptSession.TryGetReferenceForLoadedAssembly which uses
         System.Reflection.Metadata.AssemblyExtensions.TryGetRawMetadata (byte*).
         Affects only our plugin code — the C# script the user types is
         independently restricted via ScriptOptions.WithAllowUnsafe(false). -->
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="AvalonEdit" Version="6.3.0.90" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
  </ItemGroup>

  <ItemGroup>
    <!-- AvalonEdit loads syntax definitions from .xshd. Ours is embedded and
         loaded explicitly in ScriptControl.xaml.cs so the dark colours don't
         leak into other AvalonEdit instances in the process. -->
    <EmbeddedResource Include="Ui\Themes\CSharp-Dark.xshd" />

    <!-- Starter DTO set, embedded so DevReload's byte[]-loaded ALC can seed
         %LOCALAPPDATA%\Acd.Mcp\dto-system\ without a sibling-folder path
         lookup (Assembly.Location is empty in that loader). A future
         installer can extract these from the bundle directly without going
         through resource enumeration. -->
    <EmbeddedResource Include="Resources\DtoSystem\*.csx" />

    <!-- DevReload reads this side-by-side config next to Acd.Mcp.dll to
         decide which assemblies to share/stream into the default
         (non-collectible) ALC. Acd.Mcp.Api + Acd.Mcp.Contracts MUST be in
         that list — without them, the v18 G6 fix silently regresses and
         batch script bodies fail at compile/load time. The tracked
         template lives next to the csproj and is copied to $(OutputPath)
         on every build, so a fresh clone + dotnet build never produces
         a broken bin/. See G8 in CRASH_TEST_V2_JOURNAL.md. -->
    <None Include="SharedAssemblies.Config.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Scripting" Version="4.12.0" />
  </ItemGroup>

  <ItemGroup>
    <!-- AutoCAD-free runtime. Plugin provides the AutoCAD-bound host and
         session; runtime owns the loop, Outcome union, step DSL, history. -->
    <ProjectReference Include="..\Acd.Mcp.Batch\Acd.Mcp.Batch.csproj" />

    <!-- Acd.Mcp.Api carries AcadGlobals (the SCRIPT-session globalsType). It must end up
         in the default ALC, not the plugin's isolated ALC, so submission
         assemblies don't pin the isolated ALC across hot-reloads. Under
         DevReload that means adding "Acd.Mcp.Api" to the registration's
         WithSharedAssemblies(...) list — PluginManager.LoadCore then
         Assembly.LoadFrom's the side-by-side DLL into the default ALC before
         the plugin loads. The shared-name check in IsolatedPluginContext.Load
         fires before the deps.json resolver, so Private=True (default —
         needed for the side-by-side copy) is harmless.

         The AutoCAD + Civil 3D NuGet references flow through this
         ProjectReference (compile-only via ExcludeAssets=runtime on the
         Api project side), so this csproj does NOT redeclare them. -->
    <ProjectReference Include="..\Acd.Mcp.Api\Acd.Mcp.Api.csproj" />
  </ItemGroup>

  <PropertyGroup Condition=" '$(Platform)' == 'x64' ">
    <DebugSymbols>true</DebugSymbols>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Debug|x64'">
    <OutputPath>bin\Debug\</OutputPath>
    <DebugType>full</DebugType>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Release|x64'">
    <OutputPath>bin\Release\</OutputPath>
    <DebugType>full</DebugType>
  </PropertyGroup>
</Project>
